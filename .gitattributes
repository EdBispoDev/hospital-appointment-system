# .gitattributes
* text=auto

# Python
*.py text diff=python
*.pyw text
*.pyi text diff=python

# Documentação
*.md text
*.rst text
*.txt text
*.tex text
*.json text
*.yaml text
*.yml text
*.toml text
*.ini text
*.cfg text
*.conf text

# Binários
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.7z binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.db binary
*.sqlite binary
*.sqlite3 binary

# Line endings
*.sh text eol=lf
*.bash text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Export-ignore (remove do arquivo de distribuição)
.gitignore export-ignore
.gitattributes export-ignore
.github/ export-ignore
.gitlab/ export-ignore
.travis.yml export-ignore
.appveyor.yml export-ignore
.circleci/ export-ignore
.dockerignore export-ignore
.editorconfig export-ignore
.pre-commit-config.yaml export-ignore
.flake8 export-ignore
.pylintrc export-ignore
.mypy.ini export-ignore
tests/ export-ignore
docs/ export-ignore
examples/ export-ignore